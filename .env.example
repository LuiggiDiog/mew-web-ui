DATABASE_URL=postgres://workspace:workspace@localhost:5432/workspace
DATABASE_URL_TEST=postgres://workspace:workspace@localhost:5433/workspace_test
SESSION_SECRET=replace-with-a-random-secret-at-least-32-characters
SESSION_COOKIE_NAME=workspace_session

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TEST_ONLY_MODEL_ENABLED=false

COMFYUI_BASE_URL=http://192.168.1.202:8188
# Z-Image Turbo model filenames (defaults match the z_image_turbo_example workflow)
COMFYUI_UNET_MODEL=z_image_turbo_nvfp4.safetensors
COMFYUI_CLIP_MODEL=qwen_3_4b_fp4_mixed.safetensors
COMFYUI_VAE_MODEL=ae.safetensors

NEXT_PUBLIC_APP_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: normally not used because the app builds the callback URL
# from the incoming request origin (supports localhost/proxy/ngrok).
# Set this only if you need to force a fixed OAuth callback URL.
#GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
